// Электронная зачётная книжка студента
// БД: Microsoft SQL Server (видна в SQL Server Management Studio).
// Поля enum-типов хранятся как String — типизация на уровне TS в src/types/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// Допустимые значения «перечислений» см. в src/types/enums.ts:
//   Role            : STUDENT | TEACHER | HEAD
//   AssessmentType  : EXAM | CREDIT | GRADED_CREDIT
//   PracticeKind    : EDUCATIONAL | PRODUCTION | PREDIPLOMA
//   Admission       : ADMITTED | NOT_ADMITTED
//   AuditAction     : CREATE | UPDATE | DELETE | EXPORT | LOGIN | ROLE_CHANGE

// ─── Учреждение и пользователи ─────────────────────────────────────────────

model Institution {
  id        String   @id @default(cuid())
  name      String                 // полное наименование
  shortName String?                // краткое наименование
  address   String?
  ogrn      String?
  inn       String?
  logoUrl   String?
  headName  String?                // ФИО руководителя учреждения (директор)
  headTitle String?                // должность руководителя ("Директор")
  departmentHeadName  String?      // ФИО заведующего отделением (учебной частью)
  departmentHeadTitle String?      // должность ("Заведующий отделением")
  departmentName      String?      // название отделения / специальности
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String                  // Role: STUDENT | TEACHER | HEAD
  fullName     String                  // ФИО полностью
  position     String?                 // должность (для преп./зав.)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student              Student?
  teachingAssessments  Assessment[] @relation("AssessmentTeacher")
  courseWorksTaught    CourseWork[] @relation("CourseWorkTeacher")
  practicesAsInstSup   Practice[]   @relation("PracticeInstSupervisor")
  vkrSupervised        VKR[]        @relation("VKRSupervisor")
  defensesPresided     Defense[]    @relation("DefenseChair")
  stateExamsPresided   StateExam[]  @relation("StateExamChair")
  templatesEdited      DocumentTemplate[] @relation("TemplateEditor")
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
  teachingAssignments  TeachingAssignment[] @relation("TeacherAssignment")
  notifications        Notification[]       @relation("UserNotifications")
}

// ─── План преподавателя (что он ведёт) ─────────────────────────────────────
// Заведующий формирует записи: «препод X ведёт дисциплину Y в группе Z
// в семестре S, часы H». Для ВКР/защиты/гос.экзамена — привязка к конкретному
// студенту. Все формы выставления оценок преподавателем ограничены этим планом.
model TeachingAssignment {
  id           String  @id @default(cuid())
  teacherId    String
  teacher      User    @relation("TeacherAssignment", fields: [teacherId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  kind         String  // ASSESSMENT | COURSEWORK | PRACTICE | VKR | DEFENSE_CHAIR | STATE_EXAM_CHAIR
  semesterId   String?
  semester     Semester?   @relation(fields: [semesterId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  disciplineId String?
  discipline   Discipline? @relation(fields: [disciplineId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  groupId      String?
  group        Group?      @relation(fields: [groupId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  studentId    String?
  student      Student?    @relation(fields: [studentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  hours        Int?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([teacherId, kind])
}

// ─── Справочник видов ВКР (редактируется заведующим) ───────────────────────
model VkrType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Справочник председателей ГЭК (назначается приказом) ────────────────────
model GekChair {
  id        String   @id @default(cuid())
  fullName  String
  position  String?
  year      Int?     // учебный год начала (например 2025 для 2025/2026)
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Уведомления для студентов (тост в углу) ────────────────────────────────
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Учебная структура ─────────────────────────────────────────────────────

model Group {
  id         String    @id @default(cuid())
  name       String    @unique               // "ИС-21"
  speciality String?                          // специальность / направление
  startYear  Int                              // год набора
  students   Student[]
  teachingAssignments TeachingAssignment[]
}

model Student {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordBookNumber String    @unique          // номер зачётной книжки
  groupId          String
  group            Group     @relation(fields: [groupId], references: [id])
  birthDate        DateTime?
  enrollmentDate   DateTime
  enrollmentOrder  String?                    // приказ о зачислении
  expulsionDate    DateTime?
  expulsionOrder   String?
  currentCourse    Int       @default(1)

  assessments Assessment[]
  courseWorks CourseWork[]
  practices   Practice[]
  vkr         VKR?
  stateExams  StateExam[]
  teachingAssignments TeachingAssignment[]
}

model Semester {
  id           String   @id @default(cuid())
  course       Int                            // 1..6
  number       Int                            // 1 или 2 (осенний/весенний)
  academicYear String                         // "2025/2026"
  startDate    DateTime
  endDate      DateTime

  assessments Assessment[]
  courseWorks CourseWork[]
  practices   Practice[]
  teachingAssignments TeachingAssignment[]

  @@unique([course, number, academicYear])
}

model Discipline {
  id          String  @id @default(cuid())
  name        String  @unique
  totalHours  Int?
  creditUnits Float?

  assessments Assessment[]
  courseWorks CourseWork[]
  teachingAssignments TeachingAssignment[]
}

// ─── 2. Промежуточная аттестация ───────────────────────────────────────────

model Assessment {
  id             String         @id @default(cuid())
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester       @relation(fields: [semesterId], references: [id])
  disciplineId   String
  discipline     Discipline     @relation(fields: [disciplineId], references: [id])
  type           String                          // AssessmentType: EXAM | CREDIT | GRADED_CREDIT
  grade          String                          // "5" / "4" / "3" / "зачтено" / "не зачтено"
  hours          Int?
  creditUnits    Float?
  date           DateTime
  teacherId      String
  teacher        User           @relation("AssessmentTeacher", fields: [teacherId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  protocolNumber String?                         // № ведомости

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, semesterId])
}

// ─── 3. Курсовые работы ────────────────────────────────────────────────────

model CourseWork {
  id           String     @id @default(cuid())
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterId   String
  semester     Semester   @relation(fields: [semesterId], references: [id])
  disciplineId String
  discipline   Discipline @relation(fields: [disciplineId], references: [id])
  topic        String
  grade        String?                            // опционально — препод может выдать тему, оценка ставится позже
  date         DateTime?                          // дата выставления оценки; null = тема только выдана
  assignedAt   DateTime?                          // дата выдачи темы
  teacherId    String
  teacher      User       @relation("CourseWorkTeacher", fields: [teacherId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

// ─── 4. Практика ───────────────────────────────────────────────────────────

model Practice {
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterId      String
  semester        Semester     @relation(fields: [semesterId], references: [id])
  course          Int
  kind            String                          // PracticeKind: EDUCATIONAL | PRODUCTION | PREDIPLOMA
  place           String                          // место прохождения
  hours           Int?
  creditUnits     Float?
  startDate       DateTime
  endDate         DateTime
  grade           String?                         // опционально — практика может быть зафиксирована до выставления оценки
  gradeDate       DateTime?

  // Руководитель от учреждения — пользователь системы (преподаватель)
  instSupervisorId String
  instSupervisor   User         @relation("PracticeInstSupervisor", fields: [instSupervisorId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  // Руководитель от организации — внешнее лицо, храним как текст
  orgSupervisorName String?
  orgSupervisorPosition String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

// ─── 5. ГИА (ВКР) ──────────────────────────────────────────────────────────

model VKR {
  id            String    @id @default(cuid())
  studentId     String    @unique
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic         String
  type          String?                            // вид: «дипломный проект», «дипломная работа», ...
  approvedOrder String?                            // приказ об утверждении темы
  approvedDate  DateTime?
  supervisorId  String
  supervisor    User      @relation("VKRSupervisor", fields: [supervisorId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  defense Defense?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 6. Защита ВКР ─────────────────────────────────────────────────────────

model Defense {
  id             String     @id @default(cuid())
  vkrId          String     @unique
  vkr            VKR        @relation(fields: [vkrId], references: [id], onDelete: Cascade)
  admission      String                            // Admission: ADMITTED | NOT_ADMITTED
  admissionDate  DateTime?
  date           DateTime?
  grade          String?
  chairId        String?
  chair          User?      @relation("DefenseChair", fields: [chairId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  protocolNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 7. Государственный экзамен ────────────────────────────────────────────

model StateExam {
  id             String     @id @default(cuid())
  studentId      String
  student        Student    @relation(fields: [studentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  name           String                            // название экзамена
  admission      String                            // Admission: ADMITTED | NOT_ADMITTED
  admissionDate  DateTime?
  date           DateTime?
  grade          String?
  chairId        String?
  chair          User?      @relation("StateExamChair", fields: [chairId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  protocolNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

// ─── 9. Шаблоны документов (low-code) ──────────────────────────────────────

model DocumentTemplate {
  id           String   @id @default(cuid())
  code         String   @unique     // 'RECORD_BOOK', 'ATTESTATION_REPORT', ...
  name         String
  description  String?
  content      String   @db.NVarChar(Max)        // HTML/handlebars-подобный шаблон
  fieldsJson   String?  @db.NVarChar(Max)
  sectionsJson String?  @db.NVarChar(Max)
  isActive     Boolean  @default(true)
  version      Int      @default(1)

  updatedById  String?
  updatedBy    User?    @relation("TemplateEditor", fields: [updatedById], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 8. История изменений (audit log) ──────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  action    String                                  // AuditAction: CREATE | UPDATE | DELETE | EXPORT | LOGIN | ROLE_CHANGE
  entity    String                                  // 'Assessment', 'Student', ...
  entityId  String?
  diff      String?  @db.NVarChar(Max)              // JSON: { before, after }
  ip        String?
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
