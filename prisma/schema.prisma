generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Institution {
  id                  String   @id @default(cuid())
  name                String
  shortName           String?
  address             String?
  ogrn                String?
  inn                 String?
  logoUrl             String?
  headName            String?
  headTitle           String?
  city                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  departmentHeadName  String?
  departmentHeadTitle String?
  departmentName      String?
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                String
  fullName            String
  position            String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssessments Assessment[]         @relation("AssessmentTeacher")
  auditLogs           AuditLog[]
  courseWorksTaught   CourseWork[]         @relation("CourseWorkTeacher")
  defensesPresided    Defense[]            @relation("DefenseChair")
  templatesEdited     DocumentTemplate[]   @relation("TemplateEditor")
  notifications       Notification[]       @relation("UserNotifications")
  passwordResetTokens PasswordResetToken[]
  practicesAsInstSup  Practice[]           @relation("PracticeInstSupervisor")
  stateExamsPresided  StateExam[]          @relation("StateExamChair")
  student             Student?
  teachingAssignments TeachingAssignment[] @relation("TeacherAssignment")
  vkrSupervised       VKR[]                @relation("VKRSupervisor")
}

model TeachingAssignment {
  id           String      @id @default(cuid())
  teacherId    String
  kind         String
  semesterId   String?
  disciplineId String?
  groupId      String?
  studentId    String?
  hours        Int?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  discipline   Discipline? @relation(fields: [disciplineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  group        Group?      @relation(fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  semester     Semester?   @relation(fields: [semesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student      Student?    @relation(fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teacher      User        @relation("TeacherAssignment", fields: [teacherId], references: [id], onUpdate: NoAction)

  @@index([teacherId])
  @@index([teacherId, kind])
}

model VkrType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GekChair {
  id        String   @id @default(cuid())
  fullName  String
  position  String?
  year      Int?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Group {
  id                  String               @id @default(cuid())
  name                String               @unique
  speciality          String?
  startYear           Int
  students            Student[]
  teachingAssignments TeachingAssignment[]
}

model Student {
  id                  String               @id @default(cuid())
  userId              String               @unique
  recordBookNumber    String               @unique
  groupId             String
  birthDate           DateTime?
  enrollmentDate      DateTime
  enrollmentOrder     String?
  expulsionDate       DateTime?
  expulsionOrder      String?
  currentCourse       Int                  @default(1)
  academicLeaveDate   DateTime?
  academicLeaveOrder  String?
  archiveReason       String?
  assessments         Assessment[]
  courseWorks         CourseWork[]
  practices           Practice[]
  stateExams          StateExam[]
  group               Group                @relation(fields: [groupId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  teachingAssignments TeachingAssignment[]
  vkr                 VKR?
}

model Semester {
  id                  String               @id @default(cuid())
  course              Int
  number              Int
  academicYear        String
  startDate           DateTime
  endDate             DateTime
  assessments         Assessment[]
  courseWorks         CourseWork[]
  practices           Practice[]
  teachingAssignments TeachingAssignment[]

  @@unique([course, number, academicYear])
}

model Discipline {
  id                  String               @id @default(cuid())
  name                String               @unique
  totalHours          Int?
  creditUnits         Float?
  assessments         Assessment[]
  courseWorks         CourseWork[]
  teachingAssignments TeachingAssignment[]
}

model Assessment {
  id             String     @id @default(cuid())
  studentId      String
  semesterId     String
  disciplineId   String
  type           String
  grade          String
  hours          Int?
  creditUnits    Float?
  date           DateTime
  teacherId      String
  protocolNumber String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  discipline     Discipline @relation(fields: [disciplineId], references: [id])
  semester       Semester   @relation(fields: [semesterId], references: [id])
  student        Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher        User       @relation("AssessmentTeacher", fields: [teacherId], references: [id], onUpdate: NoAction)

  @@index([studentId, semesterId])
}

model CourseWork {
  id           String     @id @default(cuid())
  studentId    String
  semesterId   String
  disciplineId String
  topic        String
  grade        String?
  date         DateTime?
  teacherId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignedAt   DateTime?
  discipline   Discipline @relation(fields: [disciplineId], references: [id])
  semester     Semester   @relation(fields: [semesterId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      User       @relation("CourseWorkTeacher", fields: [teacherId], references: [id], onUpdate: NoAction)

  @@index([studentId])
}

model Practice {
  id                    String    @id @default(cuid())
  studentId             String
  semesterId            String
  course                Int
  kind                  String
  place                 String
  hours                 Int?
  creditUnits           Float?
  startDate             DateTime
  endDate               DateTime
  grade                 String?
  gradeDate             DateTime?
  instSupervisorId      String
  orgSupervisorName     String?
  orgSupervisorPosition String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  instSupervisor        User      @relation("PracticeInstSupervisor", fields: [instSupervisorId], references: [id], onUpdate: NoAction)
  semester              Semester  @relation(fields: [semesterId], references: [id])
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model VKR {
  id            String    @id @default(cuid())
  studentId     String    @unique
  topic         String
  type          String?
  approvedOrder String?
  approvedDate  DateTime?
  supervisorId  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  defense       Defense?
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  supervisor    User      @relation("VKRSupervisor", fields: [supervisorId], references: [id], onUpdate: NoAction)
}

model Defense {
  id             String    @id @default(cuid())
  vkrId          String    @unique
  admission      String
  admissionDate  DateTime?
  date           DateTime?
  grade          String?
  chairId        String?
  protocolNumber String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  chair          User?     @relation("DefenseChair", fields: [chairId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vkr            VKR       @relation(fields: [vkrId], references: [id], onDelete: Cascade)
}

model StateExam {
  id             String    @id @default(cuid())
  studentId      String
  name           String
  admission      String
  admissionDate  DateTime?
  date           DateTime?
  grade          String?
  chairId        String?
  protocolNumber String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  chair          User?     @relation("StateExamChair", fields: [chairId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student        Student   @relation(fields: [studentId], references: [id], onUpdate: NoAction)

  @@index([studentId])
}

model DocumentTemplate {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  content      String   @db.NVarChar(Max)
  fieldsJson   String?  @db.NVarChar(Max)
  sectionsJson String?  @db.NVarChar(Max)
  isActive     Boolean  @default(true)
  version      Int      @default(1)
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  updatedBy    User?    @relation("TemplateEditor", fields: [updatedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  diff      String?  @db.NVarChar(Max)
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
