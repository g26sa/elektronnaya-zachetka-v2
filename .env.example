# Microsoft SQL Server (для разработки — локальный инстанс с Windows-аутентификацией)
DATABASE_URL="sqlserver://localhost:1433;database=ezk;integratedSecurity=true;trustServerCertificate=true;encrypt=true"
# Минимум 32 символа. Сгенерировать: openssl rand -base64 48
JWT_SECRET="generate-with-openssl-rand-base64-48"
JWT_EXPIRES_IN="7d"

# Базовый URL сайта (ссылки в письмах: сброс пароля, вход)
APP_URL="http://localhost:3000"

# SMTP для писем (сброс пароля, доступ новым пользователям).
# Если не заполнено — письма не уходят, текст пишется в консоль сервера (dev).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Электронная зачётная книжка <noreply@example.com>"
