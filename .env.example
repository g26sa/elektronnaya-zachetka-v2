DATABASE_URL="file:./dev.db"
JWT_SECRET="generate-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"

# SMTP для писем восстановления пароля. Если не заполнено — письма не уходят,
# а сгенерированный пароль пишется в консоль сервера (dev-режим).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Электронная зачётная книжка <noreply@example.com>"
