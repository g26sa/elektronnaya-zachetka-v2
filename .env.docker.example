# Скопируйте этот файл в .env.docker и заполните реальными значениями.
# Запуск: docker compose --env-file .env.docker up -d --build

# Пароль пользователя sa в SQL Server.
# Требования SQL Server: минимум 8 символов, минимум 3 из 4 групп
# (заглавные, строчные, цифры, спецсимволы). Пример: Zachetka2026!
DB_PASSWORD="ChangeMe_2026!"

# Секрет для JWT. Сгенерировать: openssl rand -base64 48
JWT_SECRET="generate-with-openssl-rand-base64-48"

# Публичный адрес сервера (IP или домен), под которым приложение доступно снаружи.
# Используется в ссылках писем (сброс пароля и т.п.).
APP_URL="http://YOUR_SERVER_IP"

# При SEED=1 после первого запуска в базу будут добавлены демо-данные (см. prisma/seed.ts).
SEED=1

# SMTP для писем восстановления пароля (можно оставить пустыми — письма уйдут в лог контейнера)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Электронная зачётная книжка <noreply@example.com>"
